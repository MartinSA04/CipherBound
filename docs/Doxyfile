PROJECT_NAME           = "CipherBound"
PROJECT_BRIEF          = "Pokemon-inspired RPG built in C++20 with SDL2"
OUTPUT_DIRECTORY       = docs
STRIP_FROM_PATH        = .
LAYOUT_FILE            = docs/doxygen/layout.xml

INPUT                  = src docs/doxygen
FILE_PATTERNS          = *.h *.hpp *.hh *.md *.dox
RECURSIVE              = YES

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
HIDE_FRIEND_COMPOUNDS  = YES
HIDE_IN_BODY_DOCS      = YES

JAVADOC_AUTOBRIEF      = YES
SORT_MEMBER_DOCS       = NO
GROUP_NESTED_COMPOUNDS = YES
ALPHABETICAL_INDEX     = NO

WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

GENERATE_HTML          = YES
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO
DISABLE_INDEX          = NO
GENERATE_LATEX         = NO

USE_MDFILE_AS_MAINPAGE = docs/doxygen/mainpage.md
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 2

SHOW_INCLUDE_FILES     = NO
SHOW_FILES             = NO
SHOW_NAMESPACES        = NO
SOURCE_BROWSER         = NO
REFERENCES_RELATION    = YES
REFERENCED_BY_RELATION = YES

HAVE_DOT               = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
